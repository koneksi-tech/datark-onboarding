# Managed by Ansible — {{ tls_host }} (load balancer with health-check failover)
upstream kipfs_pool {
{% for h in groups['kipfs_nodes'] %}
    server {{ hostvars[h].priv_ip }}:{{ kipfs_gateway_port }} max_fails=2 fail_timeout=10s;   # {{ hostvars[h].node_name }}
{% endfor %}
}

server {
    listen 80;
    server_name {{ tls_host }};
    return 301 https://$host$request_uri;
}
server {
    listen 443 ssl;
    server_name {{ tls_host }};

    ssl_certificate     {{ tls_cert_dest }};
    ssl_certificate_key {{ tls_key_dest }};

    client_max_body_size 10G;

    location / {
        proxy_pass http://kipfs_pool;
        # health-check: a failing node is marked down + skipped; retry the next healthy node
        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 3;
        proxy_connect_timeout 4s;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
