# Copy to .env and fill in once you have the clusters. .env is gitignored.

# --- This environment's Vault (NOT the prod koneksi vault) ---
VAULT_ADDR=https://vault.datark.example.com
VAULT_TOKEN=                      # provisioner token (see vault/provisioner-policy.hcl)
VAULT_KV_MOUNT=secret
VAULT_TRANSIT_MOUNT=transit

# --- Kubernetes ---
KUBE_CONTEXT=                     # optional; blank = current kubeconfig context
NS_PREFIX=tenant-                 # namespace = <prefix><tenant-id>

# --- Product ---
DOMAIN=datark.koneksi.co.kr       # tenant URL = <id>.<DOMAIN>; wildcard DNS+TLS required
IMAGE_PULL_SECRET=ncr-regcred
